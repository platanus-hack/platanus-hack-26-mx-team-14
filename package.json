{
  "name": "brisk-camel",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "turbo run dev",
    "dev:api": "pnpm --filter @sat/api dev",
    "dev:worker": "pnpm --filter @sat/worker dev",
    "dev:frontend": "pnpm --filter @sat/frontend dev",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "db:generate": "pnpm --filter @sat/db db:generate",
    "db:migrate": "pnpm --filter @sat/db db:migrate",
    "db:push": "pnpm --filter @sat/db db:push"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.6.3",
    "tsx": "^4.19.2",
    "@types/node": "^22.9.0"
  },
  "pnpm": {
    "overrides": {
      "ioredis": "5.11.1"
    }
  }
}
