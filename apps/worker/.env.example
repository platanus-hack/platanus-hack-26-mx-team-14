# apps/worker/.env — copy to apps/worker/.env. Loaded by docker-compose (env_file)
# and by `pnpm dev:worker` for local (non-docker) runs.

POSTGRES_CONNECTION_STRING=postgresql://postgres:postgres@localhost:5432/brisk_camel
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=change-me-redis

ANTHROPIC_API_KEY=sk-ant-...
VOYAGE_API_KEY=pa-...
FIRECRAWL_API_KEY=fc-...
ENCRYPTION_KEY=

# Scraper backend: playwright (local default) | firecrawl
SAT_DRIVER=playwright
ARTIFACTS_DIR=./artifacts-local
CAPTCHA_MAX_ATTEMPTS=3
