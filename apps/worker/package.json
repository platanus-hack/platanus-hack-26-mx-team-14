{
  "name": "@sat/worker",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "esbuild src/index.ts --bundle --platform=node --format=esm --outfile=dist/index.js --external:playwright --external:sharp --banner:js=\"import{createRequire}from'module';const require=createRequire(import.meta.url);\"",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "echo ok"
  },
  "dependencies": {
    "@sat/shared": "workspace:*",
    "@sat/events": "workspace:*",
    "@sat/db": "workspace:*",
    "@sat/scraper": "workspace:*",
    "bullmq": "^5.28.1",
    "ioredis": "^5.4.1",
    "drizzle-orm": "^0.36.4"
  },
  "devDependencies": {
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "@types/node": "^22.9.0"
  }
}
