# apps/api/.env — copy to apps/api/.env. Loaded by docker-compose (env_file) and
# by `pnpm dev:api` for local (non-docker) runs.

# Local dev (non-docker) connection strings. In docker these are injected by compose.
POSTGRES_CONNECTION_STRING=postgresql://postgres:postgres@localhost:5432/brisk_camel
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=change-me-redis

HOST=0.0.0.0
PORT=3000
WEB_ORIGIN=http://localhost:3001

ANTHROPIC_API_KEY=sk-ant-...
ENCRYPTION_KEY=

# Voice provider for the webhook route: vapi | elevenlabs
VOICE_PROVIDER=vapi
VAPI_API_KEY=
VAPI_WEBHOOK_SECRET=
ELEVENLABS_API_KEY=

# Demo identity for the voice webhook (maps a call → user/credential).
DEMO_USER_ID=demo-user
DEMO_CREDENTIAL_ID=
DEMO_RFC=XAXX010101000
