# Dev image for the frontend app (@sat/frontend). Source is bind-mounted by
# compose; node_modules live in anonymous volumes seeded from this image.
FROM node:22-bookworm-slim

ENV PNPM_HOME=/pnpm
ENV PATH=$PNPM_HOME:$PATH
RUN corepack enable

WORKDIR /app

COPY pnpm-workspace.yaml pnpm-lock.yaml package.json ./
COPY packages ./packages
COPY apps/frontend ./apps/frontend
RUN pnpm install --frozen-lockfile || pnpm install

EXPOSE 3001
CMD ["pnpm", "--filter", "@sat/frontend", "dev"]
