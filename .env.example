# ──────────────────────────────────────────────────────────────────────────
# Root .env — used by docker-compose for ${VAR} interpolation AND by the
# postgres/redis containers (env_file: .env). Copy to .env and fill in.
# Per-app overrides live in apps/<app>/.env (see apps/*/.env.example).
# ──────────────────────────────────────────────────────────────────────────

NODE_ENV=development

# --- Postgres container (pgvector) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=brisk_camel
POSTGRES_PORT=5432

# --- Redis container ---
REDIS_PORT=6379
REDIS_PASSWORD=change-me-redis

# --- Ports ---
API_PORT=3000
FRONTEND_PORT=3001

# --- AI / external ---
ANTHROPIC_API_KEY=sk-ant-...
VOYAGE_API_KEY=pa-...
# SAT scraper driver. Default (and prod) is playwright — set it EXPLICITLY in
# every deploy (Render worker too) so prod can never silently diverge to firecrawl.
SAT_DRIVER=playwright
FIRECRAWL_API_KEY=fc-...
ELEVENLABS_API_KEY=

# --- Credential encryption (AES-256-GCM). 32 bytes, base64. ---
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_KEY=

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:3000
